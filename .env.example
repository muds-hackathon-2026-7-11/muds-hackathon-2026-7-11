# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seminar_platform

# --- API (apps/api) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/seminar_platform
JWT_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=
ANTHROPIC_API_KEY=
# 開発用ダミー認証: true のとき実JWT検証を行わず X-Dev-User-Email ヘッダの
# ユーザーとして認証する(未指定なら AUTH_DEV_USER_EMAIL)。
# ローカル/CI専用。本番では必ず false にすること。
AUTH_DEV_MODE=true
AUTH_DEV_USER_EMAIL=dev-student@example.com

# --- Slack Bot (services/slack-bot, Socket Mode) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
WEB_APP_URL=http://localhost:3100
API_BASE_URL=http://api:8000

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:8100
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
