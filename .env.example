# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seminar_platform

# --- API (apps/api) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/seminar_platform
# JWT検証(実Googleログイン時に使用。AUTH_DEV_MODE=false のとき有効)。
# issuer/audience は web(apps/web)の AUTH_JWT_* と一致させること。
# JWT_JWKS_URL 例: http://web:3000/api/auth/jwks (Docker) / http://localhost:3000/api/auth/jwks (ローカル)
JWT_JWKS_URL=
JWT_ISSUER=seminar-platform-web
JWT_AUDIENCE=seminar-platform-api
ANTHROPIC_API_KEY=
# 開発用ダミー認証: true のとき実JWT検証を行わず X-Dev-User-Email ヘッダの
# ユーザーとして認証する(未指定なら AUTH_DEV_USER_EMAIL)。
# ローカル/CI専用。本番では必ず false にすること。
AUTH_DEV_MODE=true
AUTH_DEV_USER_EMAIL=dev-student@example.com

# --- Slack Bot (services/slack-bot, Socket Mode) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
WEB_APP_URL=http://localhost:3100
API_BASE_URL=http://api:8000
# web-api間のみで完結する合言葉。/users/exists 等、ログイン前(未認証)に
# 呼ぶ必要があるためJWT検証を通せないエンドポイントの直叩き対策として使う。
# 生成: openssl rand -hex 32
INTERNAL_API_SECRET=

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:8100
# Auth.jsが使う公開URL。Docker(3100→内部3000)やプロキシ下では明示が必須。
# 未設定だと内部ポート3000でコールバックURLを組み立て、ログイン後にリダイレクトが
# localhost:3000 になって接続拒否になる。ローカルの pnpm dev 直叩き時は http://localhost:3000。
AUTH_URL=http://localhost:3100
# Google OAuth クライアント(Google Cloud Consoleで発行)。
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Auth.jsのセッション暗号化キー。生成: openssl rand -base64 32
AUTH_SECRET=
# API向けRS256アクセストークン(発行側)。issuer/audienceはバックエンドのJWT_*と一致させる。
AUTH_JWT_ISSUER=seminar-platform-web
AUTH_JWT_AUDIENCE=seminar-platform-api
# RS256秘密鍵JWK(単一行JSON)。生成:
#   cd apps/web && node --input-type=module -e "import{generateKeyPair,exportJWK}from'jose';const{privateKey}=await generateKeyPair('RS256',{extractable:true});process.stdout.write(JSON.stringify(await exportJWK(privateKey)))"
AUTH_JWT_PRIVATE_KEY=
# ログイン許可メールドメイン(カンマ区切り)。空なら全Googleアカウント許可。例: stu.musashino-u.ac.jp
AUTH_ALLOWED_EMAIL_DOMAINS=
